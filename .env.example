# ============================================================
# Music Education Platform — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit the .env file!
# ============================================================

# ── Database (main platform) ────────────────────────────────
POSTGRES_USER=musicedu
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD
POSTGRES_DB=musicedu
DATABASE_URL=******postgres-main:5432/musicedu

# ── Redis (main platform) ───────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis-main:6379

# ── Authentication (JWT) ────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING

# ── Keycloak (central identity provider) ────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_THIS_KEYCLOAK_PASSWORD
KEYCLOAK_CLIENT_ID=musicedu-web
KEYCLOAK_CLIENT_SECRET=CHANGE_THIS_KEYCLOAK_SECRET
KEYCLOAK_ISSUER=http://auth.musicedu.test/realms/musicedu

# ── NextAuth ────────────────────────────────────────────────
NEXTAUTH_URL=http://app.musicedu.test
NEXTAUTH_SECRET=CHANGE_THIS_NEXTAUTH_SECRET

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_CHANGE_THIS
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_THIS

# ── Yapeal (optional Swiss payment) ─────────────────────────
YAPEAL_API_KEY=CHANGE_THIS

# ── Zoom Integration ────────────────────────────────────────
ZOOM_API_KEY=CHANGE_THIS
ZOOM_API_SECRET=CHANGE_THIS
ZOOM_ACCOUNT_ID=CHANGE_THIS

# ── AI (DeepSeek) ───────────────────────────────────────────
DEEPSEEK_API_KEY=CHANGE_THIS
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# ── AI (OpenAI) ─────────────────────────────────────────────
OPENAI_API_KEY=CHANGE_THIS

# ── AI (Claude / Anthropic) ─────────────────────────────────
CLAUDE_API_KEY=CHANGE_THIS

# ── MinIO (Object Storage) ──────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_THIS_MINIO_PASSWORD
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_NAME=musicedu-media

# ── Application ─────────────────────────────────────────────
FRONTEND_URL=http://app.musicedu.test
CORS_ORIGIN=http://app.musicedu.test
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ── Next.js public env ──────────────────────────────────────
NEXT_PUBLIC_GRAPHQL_URL=http://api.musicedu.test/graphql
NEXT_PUBLIC_GRAPHQL_WS_URL=ws://api.musicedu.test/graphql
NEXT_PUBLIC_PRETIX_WIDGET_URL=http://tickets.musicedu.test

# ============================================================
# Moodle (online-learning core)
# ============================================================
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=CHANGE_THIS_MOODLE_DB_PASSWORD
MOODLE_DB_NAME=moodle
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=CHANGE_THIS_MOODLE_ADMIN_PASSWORD
MOODLE_ADMIN_EMAIL=admin@musicedu.app
MOODLE_URL=http://moodle:8080
MOODLE_WS_TOKEN=CHANGE_THIS_MOODLE_WS_TOKEN
MOODLE_OIDC_CLIENT_ID=moodle-oidc
MOODLE_OIDC_CLIENT_SECRET=CHANGE_THIS_MOODLE_OIDC_SECRET

# ============================================================
# LibreBooking (physical lesson scheduling core)
# ============================================================
LIBREBOOKING_DB_USER=librebooking
LIBREBOOKING_DB_PASSWORD=CHANGE_THIS_LIBREBOOKING_DB_PASSWORD
LIBREBOOKING_DB_NAME=librebooking
LIBREBOOKING_DB_ROOT_PASSWORD=CHANGE_THIS_LIBREBOOKING_ROOT_PASSWORD
LIBREBOOKING_TIMEZONE=Europe/Zurich
LIBREBOOKING_ADMIN_EMAIL=admin@musicedu.app
LIBREBOOKING_URL=http://librebooking:80
LIBREBOOKING_API_USER=admin
LIBREBOOKING_API_PASSWORD=CHANGE_THIS_LIBREBOOKING_API_PASSWORD
LIBREBOOKING_OIDC_CLIENT_ID=librebooking-saml
LIBREBOOKING_OIDC_CLIENT_SECRET=CHANGE_THIS_LIBREBOOKING_OIDC_SECRET

# ============================================================
# pretix (event ticketing core)
# ============================================================
PRETIX_DB_USER=pretix
PRETIX_DB_PASSWORD=CHANGE_THIS_PRETIX_DB_PASSWORD
PRETIX_DB_NAME=pretix
PRETIX_REDIS_PASSWORD=CHANGE_THIS_PRETIX_REDIS_PASSWORD
PRETIX_URL=http://pretix:8345
PRETIX_API_TOKEN=CHANGE_THIS_PRETIX_API_TOKEN
PRETIX_ORGANISER_SLUG=musicedu
PRETIX_CURRENCY=CHF
PRETIX_WEBHOOK_SECRET=CHANGE_THIS_PRETIX_WEBHOOK_SECRET
PRETIX_MAIL_FROM=tickets@musicedu.app
PRETIX_MAIL_HOST=localhost
PRETIX_MAIL_PORT=587
PRETIX_MAIL_USER=
PRETIX_MAIL_PASSWORD=
PRETIX_OIDC_CLIENT_ID=pretix-oidc
PRETIX_OIDC_CLIENT_SECRET=CHANGE_THIS_PRETIX_OIDC_SECRET
