# ============================================================
# Music Education Platform — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit the .env file!
# ============================================================

# ── Database ────────────────────────────────────────────────
POSTGRES_USER=musicedu
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD
POSTGRES_DB=musicedu
DATABASE_URL=******localhost:5432/musicedu

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@localhost:6379

# ── Authentication (JWT) ────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING

# ── Keycloak (OpenID Connect) ────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_THIS_KEYCLOAK_PASSWORD
KEYCLOAK_CLIENT_ID=musicedu-web
KEYCLOAK_CLIENT_SECRET=CHANGE_THIS_KEYCLOAK_SECRET
KEYCLOAK_ISSUER=http://localhost:8080/realms/musicedu

# ── NextAuth ────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_THIS_NEXTAUTH_SECRET

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_CHANGE_THIS
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_THIS

# ── Yapeal (optional Swiss payment) ─────────────────────────
YAPEAL_API_KEY=CHANGE_THIS

# ── Zoom Integration ─────────────────────────────────────────
ZOOM_API_KEY=CHANGE_THIS
ZOOM_API_SECRET=CHANGE_THIS
ZOOM_ACCOUNT_ID=CHANGE_THIS

# ── Calendly Integration ─────────────────────────────────────
CALENDLY_ACCESS_TOKEN=CHANGE_THIS

# ── AI (DeepSeek) ────────────────────────────────────────────
DEEPSEEK_API_KEY=CHANGE_THIS
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# ── AI (OpenAI) ──────────────────────────────────────────────
OPENAI_API_KEY=CHANGE_THIS

# ── AI (Claude / Anthropic) ──────────────────────────────────
CLAUDE_API_KEY=CHANGE_THIS

# ── MinIO (Object Storage) ──────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_THIS_MINIO_PASSWORD
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_NAME=musicedu-media

# ── Application ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ── Next.js public env ──────────────────────────────────────
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_GRAPHQL_WS_URL=ws://localhost:4000/graphql
