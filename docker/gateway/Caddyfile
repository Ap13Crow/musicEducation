# ── Caddy Reverse Proxy ──────────────────────────────────────
# Subdomain-based routing for local development.
# All services are accessed through *.musicedu.test

{
	# Local development — no HTTPS auto-provisioning
	auto_https off
	admin off
}

# ── Main web app ─────────────────────────────────────────────
app.musicedu.test {
	reverse_proxy web:3000
}

# ── GraphQL API ──────────────────────────────────────────────
api.musicedu.test {
	reverse_proxy api:4000
}

# ── Keycloak (identity provider) ─────────────────────────────
auth.musicedu.test {
	reverse_proxy keycloak:8080
}

# ── Moodle (online learning) ────────────────────────────────
learn.musicedu.test {
	reverse_proxy moodle:8080
}

# ── LibreBooking (physical scheduling) ──────────────────────
booking.musicedu.test {
	reverse_proxy librebooking:80
}

# ── pretix (event ticketing) ────────────────────────────────
tickets.musicedu.test {
	reverse_proxy pretix:8345
}
