{
  "realm": "mymusic-coach",
  "enabled": true,
  "displayName": "My Music Coach",
  "displayNameHtml": "<b>🎵 My Music Coach</b>",
  "accessTokenLifespan": 900,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "sslRequired": "external",
  "smtpServer": {
    "host": "mail.infomaniak.com",
    "port": "587",
    "from": "admin@mymusic.coach",
    "fromDisplayName": "My Music Coach",
    "replyTo": "admin@mymusic.coach",
    "ssl": "false",
    "starttls": "true",
    "auth": "true",
    "user": "admin@mymusic.coach",
    "password": ""
  },
  "clients": [
    {
      "clientId": "mymusic-coach-web",
      "name": "My Music Coach Web App",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://app.mymusic-coach.test/*",
        "http://localhost:3000/*",
        "https://mymusic.coach/*"
      ],
      "webOrigins": [
        "http://app.mymusic-coach.test",
        "http://localhost:3000",
        "https://mymusic.coach"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "mymusic-coach-api",
      "name": "My Music Coach API",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "moodle-oidc",
      "name": "Moodle LMS",
      "description": "OIDC client for Moodle SSO (admins/teachers) and web-service token.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://learn.mymusic-coach.test/*",
        "https://learn.mymusic.coach/*"
      ],
      "webOrigins": [
        "http://learn.mymusic-coach.test",
        "https://learn.mymusic.coach"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "attributes": {}
    },
    {
      "clientId": "pretix-oidc",
      "name": "pretix (Customer Account OIDC Login)",
      "description": "OpenID Connect client for pretix customer-account SSO",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://tickets.mymusic-coach.test/mymusic-coach/account/*",
        "https://tickets.mymusic.coach/mymusic-coach/account/*"
      ],
      "webOrigins": [
        "http://tickets.mymusic-coach.test",
        "https://tickets.mymusic.coach"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "attributes": {}
    },
    {
      "clientId": "librebooking-saml",
      "name": "LibreBooking (Keycloak OIDC)",
      "description": "OpenID Connect client for LibreBooking scheduling SSO via keycloak-auth.php",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://booking.mymusic-coach.test/Web/keycloak-auth.php",
        "https://booking.mymusic.coach/Web/keycloak-auth.php"
      ],
      "webOrigins": [
        "http://booking.mymusic-coach.test"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "attributes": {}
    }
  ],
  "roles": {
    "realm": [
      { "name": "GUEST", "description": "Unauthenticated guest user" },
      { "name": "STUDENT", "description": "Registered student" },
      { "name": "TEACHER", "description": "Certified teacher" },
      { "name": "ADMIN", "description": "Platform administrator" }
    ]
  },
  "defaultRoles": ["STUDENT"]
}
